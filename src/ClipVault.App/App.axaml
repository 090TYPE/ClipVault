<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:ClipVault.App.Converters"
             x:Class="ClipVault.App.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <conv:PathToThumbnailConverter x:Key="PathToThumbnail"/>
        <conv:EnumEqualsConverter x:Key="EnumEquals"/>
        <conv:EnumEqualsConverter x:Key="EnumNotEquals" Invert="True"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/tray.ico" ToolTipText="ClipVault">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open history" Click="OnOpenHistory"/>
                        <NativeMenuItem Header="Settings" Click="OnOpenSettings"/>
                        <NativeMenuItem Header="-"/>
                        <NativeMenuItem Header="Quit" Click="OnQuit"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
